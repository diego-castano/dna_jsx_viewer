generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model File {
  id            String   @id @default(cuid())
  filename      String
  title         String   @default("")
  description   String   @default("")
  size          Int
  url           String
  cloudinaryId  String   @unique
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("files")
}
